APP_NAME="Studio 3GHD"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Produzione: APP_ENV=production · APP_DEBUG=false · APP_URL=https://studio.3ghomedesign.it

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Produzione: LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=studio_db
DB_PORT=3306
DB_DATABASE=studio3ghd
DB_USERNAME=studio_user
DB_PASSWORD=
DB_ROOT_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
# Locale fallback: QUEUE_CONNECTION=database

CACHE_STORE=redis
# Locale fallback: CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=studio_redis
REDIS_PASSWORD=null
REDIS_PORT=6379
# Locale: REDIS_HOST=127.0.0.1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@3ghomedesign.it"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# AI locale (Ollama — default, nessuna API key necessaria)
OLLAMA_URL=http://studio_ollama:11434
OLLAMA_MODEL=qwen2.5vl:3b

# Claude AI (fallback se ANTHROPIC_API_KEY è presente)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
